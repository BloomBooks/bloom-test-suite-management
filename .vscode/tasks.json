{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "prepare-import",
			"type": "shell",
			"command": "node",
			"args": [
				"prepare-import.mjs",
				"Bloom Test Plan.csv",
				"output"
			],
			"isBackground": false
		},
		{
			"label": "prepare-import (all cases)",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/c",
				"set IMPORT_LIMIT_CASES=0&& node prepare-import.mjs \"Bloom Test Plan.csv\" output"
			],
			"isBackground": false
		},
		{
			"label": "import-to-notion",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$env:NOTION_TOKEN=$env:BLOOM_TESTCASE_NOTION; node import-to-notion.mjs output"
			],
			"isBackground": false
		}
	]
}
