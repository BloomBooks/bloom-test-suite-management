{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "prepare-import",
			"type": "shell",
			"command": "node",
			"args": [
				"prepare-import.mjs"
			],
			"options": {
				"cwd": "${workspaceFolder}/import"
			},
			"isBackground": false
		},
		{
			"label": "prepare-import (all cases)",
			"type": "shell",
			"command": "node",
			"args": [
				"prepare-import.mjs"
			],
			"options": {
				"cwd": "${workspaceFolder}/import",
				"env": {
					"IMPORT_LIMIT_CASES": "0"
				}
			},
			"isBackground": false
		},
		{
			"label": "import-to-notion",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$env:NOTION_TOKEN=$env:BLOOM_TESTCASE_NOTION; node import-to-notion.mjs output"
			],
			"options": {
				"cwd": "${workspaceFolder}/import"
			},
			"isBackground": false
		}
	]
}
